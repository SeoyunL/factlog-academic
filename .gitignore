# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# coverage.py run artifacts — `pytest --cov` works again as of #278
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/

# factlog: runs/*.json is NOT an artifact — it is the SOURCE OF TRUTH that
# facts/candidates.csv is rebuilt from on every merge. Losing it destroys every
# reviewed fact (#218), so a version-controlled KB MUST commit it.
# Only the text conversions under runs/sources/ are regenerable (factlog ingest).
runs/sources/

# oh-my-claudecode session/runtime state — local only, never committed
.omc/

# Zotero integration — personal settings & secrets, never committed
zotero-config.toml
config.local.toml
*.key
credentials.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local agent permission list — machine-specific, never shared.
.claude/settings.local.json
